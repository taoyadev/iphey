{
  "name": "iphey",
  "version": "0.1.0",
  "description": "Digital identity and fingerprint inspection service",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc -p tsconfig.json",
    "build:worker": "tsc -p tsconfig.json",
    "start": "wrangler dev",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.json src --ext .ts --max-warnings 0",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.json src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "coverage": "vitest run --coverage",
    "health": "node scripts/health-check.js",
    "web:dev": "npm run dev --prefix apps/web-next",
    "web:build": "npm run build --prefix apps/web-next",
    "web:preview": "npm run preview --prefix apps/web-next",
    "web:lint": "npm run lint --prefix apps/web-next",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:tail": "wrangler tail",
    "kv:create": "wrangler kv:namespace create IP_CACHE && wrangler kv:namespace create IP_CACHE --preview",
    "kv:list": "wrangler kv:key list --namespace-id=$KV_ID",
    "prepare": "husky"
  },
  "keywords": [
    "ip",
    "fingerprint",
    "typescript"
  ],
  "author": "iphey contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "hono": "4.10.6",
    "lru-cache": "^11.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251120.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint -c .eslintrc.json --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
