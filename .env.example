# IPhey Worker API Configuration
# Copy this file to .env for local tooling. Production Worker values come from
# wrangler.toml vars plus Cloudflare/GitHub secrets.

# Primary: IPbot IP intelligence provider
# Key is read from env only — never commit the real key.
IPBOT_API_ORIGIN=https://api.ipbot.com
IPBOT_API_KEY=your_ipbot_api_key_here
# IPBOT_TIMEOUT_MS=4000
# IPBOT_MAX_RETRIES=3
# CACHE_TTL_IPBOT_MS=86400000           # 24h for clean results
# CACHE_TTL_IPBOT_HIGH_RISK_MS=3600000  # 1h for high-risk results

# Optional fallback/enrichment providers
IPINFO_TOKEN=your_ipinfo_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_RADAR_TOKEN=your_cloudflare_radar_token
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Worker/tooling configuration
NODE_ENV=development
LOG_LEVEL=info

# Caching
CACHE_BACKEND=memory
CACHE_TTL_MS=300000
CACHE_STALE_TTL_MS=1800000
CACHE_MAX_ITEMS=500
CLIENT_TIMEOUT_MS=2500

# Creepjs Assets
CREEPJS_ASSETS_PATH=../creepjs/dist
